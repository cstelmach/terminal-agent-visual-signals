#!/bin/bash
# ==============================================================================
# TAVS - Terminal Agent Visual Signals — User Configuration (v3)
# ==============================================================================
# Quick config:  tavs set <key> <value>     (e.g., tavs set theme nord)
# Full wizard:   tavs wizard                (interactive 7-step setup)
# See current:   tavs status                (visual summary with color preview)
# Validate:      tavs config validate       (check for errors)
#
# How it works:
#   - Uncomment and modify settings you want to override
#   - Global settings affect all agents
#   - Use AGENT_ prefix (CLAUDE_, GEMINI_, etc.) for per-agent overrides
#   - Leave settings commented to use defaults from defaults.conf
#
# Quick disable (without editing): TAVS_STATUS=false claude
# ==============================================================================


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 1: ESSENTIAL SETTINGS                                           ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# Operating Mode: "static", "dynamic", or "preset"
#   static  - Fixed colors from defaults.conf
#   dynamic - Query terminal for current background, compute colors dynamically
#   preset  - Use a named theme from src/themes/ (recommended)
# THEME_MODE="static"

# Theme preset (when THEME_MODE="preset")
#   catppuccin-frappe, catppuccin-latte, catppuccin-macchiato, catppuccin-mocha,
#   nord, dracula, solarized-dark, solarized-light, tokyo-night
# THEME_PRESET=""

# Light/Dark Mode
#   ENABLE_LIGHT_DARK_SWITCHING: Auto-detect system appearance
#     "false" (default) - Always use dark backgrounds
#     "true"  - Switch based on system appearance
#   FORCE_MODE: Explicit override (takes priority over auto-detection)
#     "auto" (default), "dark", or "light"
# ENABLE_LIGHT_DARK_SWITCHING="false"
# FORCE_MODE="auto"


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 2: VISUAL FEATURES                                              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# ASCII Faces (Anthropomorphising) — face expressions in terminal titles
# ENABLE_ANTHROPOMORPHISING="true"
# FACE_POSITION="before"    # "before" or "after" the title text

# Face Mode — standard text eyes or compact emoji eyes
#   "standard" (default) - Text eyes: Ǝ[• •]E 🟠 +2 🦊 ~/proj
#   "compact"  - Emoji eyes: Ǝ[🟧 +2]E 🦊 ~/proj (more info-dense)
# TAVS_FACE_MODE="standard"
# TAVS_COMPACT_THEME="squares"     # semantic, circles, squares, mixed

# ── Compact Context Eye ──────────────────────────────────────────────────
# When compact mode is active, the right eye shows context window fill level
# instead of duplicating the left eye's status color.
#
# Two-signal dashboard: left eye = state color, right eye = context fill
#   Ǝ[🟧 🧀]E   (processing + 50% context)
#   Ǝ[🟥 🍔]E   (permission + 85% context)
#   Ǝ[— —]E     (reset — em dash resting eyes)
#
# When no context data is available, right eye falls back to theme emoji.
# When disabled, original compact behavior is restored (both eyes = status).
#
# TAVS_COMPACT_CONTEXT_EYE="true"     # "true" (default) | "false"
# TAVS_COMPACT_CONTEXT_STYLE="food"   # Style for right eye (see table below)
#
# Available styles:
#   food      — 21-stage food emoji (💧→🧀→🍫, 5% steps) — DEFAULT
#   food_10   — 11-stage food emoji (💧→🧀→🍫, 10% steps)
#   circle    — Color circles (⚪→🟡→🔴→⚫)
#   block     — Vertical block char (▁▂▃▄▅▆▇█)
#   block_max — Vertical block + max reference (▄▒)
#   braille   — Braille fill (⠀⠄⠤⠴⠶⠷⠿)
#   number    — Number emoji (0️⃣ through 🔟)
#   percent   — Text percentage (25%, 50%, etc.)
#
# Per-agent overrides (highest priority):
#   CLAUDE_COMPACT_CONTEXT_STYLE="food"
#   GEMINI_COMPACT_CONTEXT_STYLE="block"
#   CODEX_COMPACT_CONTEXT_EYE="false"
#
# Subagent count (+N) moves to the {AGENTS} title token when context eye
# is active, keeping it visible outside the face frame.

# Stylish Backgrounds (Images) — iTerm2 and Kitty only
# ENABLE_STYLISH_BACKGROUNDS="false"
# STYLISH_BACKGROUNDS_DIR="$HOME/.tavs/backgrounds"

# Palette Theming (OSC 4) — modify terminal's 16-color ANSI palette
#   "false" (default) - Background colors only
#   "auto"  - Enable when NOT in TrueColor mode
#   "true"  - Always apply palette (affects shell tools, ls colors, etc.)
# ENABLE_PALETTE_THEMING="false"

# Status Icons — emoji shown per state in titles
# STATUS_ICON_PROCESSING="🟠"
# STATUS_ICON_PERMISSION="🔴"
# STATUS_ICON_COMPLETE="🟢"
# STATUS_ICON_IDLE="🟣"
# STATUS_ICON_COMPACTING="🔄"
# STATUS_ICON_SUBAGENT="🔀"
# STATUS_ICON_TOOL_ERROR="❌"


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 3: TITLE SYSTEM                                                 ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# Title Mode — how TAVS handles terminal tab titles
#   "skip-processing" (default) - Let Claude Code handle processing, TAVS handles others
#   "prefix-only" - Add face+status prefix, preserve your tab names
#   "full"   - TAVS owns all titles with animated spinner eyes
#   "off"    - No title changes, only background colors/images
#
# For "full" mode, add to ~/.claude/settings.json:
#   "env": { "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1" }
# TAVS_TITLE_MODE="skip-processing"

# Title Fallback — when no user-set tab name exists
#   "path"         (default) - Current directory: ~/projects
#   "session-path" - Session ID + path: 134eed79 ~/projects
#   "path-session" - Path + session ID: ~/projects 134eed79
#   "session"      - Session ID only: 134eed79
# TAVS_TITLE_FALLBACK="path"

# Title Format — customize composition template
#   {FACE}         Agent face expression (Ǝ[• •]E)
#   {STATUS_ICON}  State emoji (🟠)
#   {AGENTS}       Subagent count (+2) — empty when none
#   {SESSION_ICON} Session animal emoji per tab (🦊) — deterministic per session_id
#   {DIR_ICON}     Directory flag emoji (🇩🇪) — deterministic per cwd (dual mode only)
#   {SESSION_ID}   First 8 chars of Claude session ID (abc123de)
#   {BASE}         Base title (your tab name or fallback)
# TAVS_TITLE_FORMAT="{FACE} {STATUS_ICON} {AGENTS} {SESSION_ICON} {BASE}"

# Subagent count format — {N} = count number
# TAVS_AGENTS_FORMAT="+{N}"

# Session Icons — unique animal emoji per terminal tab
# ENABLE_SESSION_ICONS="true"
# Custom icon pool (override the default ~25 animals):
# TAVS_SESSION_ICONS=("🦄" "🐲" "🦈" "🐋" "🐠")

# ── Identity System ───────────────────────────────────────────────────────
# Deterministic icon assignment: same session always gets the same animal,
# same directory always gets the same flag. Replaces random-per-TTY icons.
#
# Modes:
#   "dual"   (default) - Session animal + directory flag, title: «🇩🇪|🦊»
#   "single" - Deterministic session animal only, no directory flag
#   "off"    - Legacy random-per-TTY behavior (25 animals, like TAVS v2)
#
# TAVS_IDENTITY_MODE="dual"
#
# Persistence — where identity registries are stored
#   "ephemeral"  (default) - /tmp/tavs/ — fresh icons after reboot
#   "persistent" - ~/.cache/tavs/ — same icon forever
# TAVS_IDENTITY_PERSISTENCE="ephemeral"
#
# Directory icon pool type — what emoji represent directories
#   "flags"     (default) - Country flags (🇩🇪 🇯🇵 🇺🇸) — ~190 icons
#   "plants"    - Plants/trees (🌳 🌴 🌵) — ~26 icons
#   "buildings" - Buildings (🏠 🏢 🏰) — ~24 icons
# TAVS_DIR_ICON_TYPE="flags"
#
# Directory identity source — how the directory path is resolved
#   "cwd"      (default) - Use working directory as-is
#   "git-root" - Normalize to git repository root (subdirs share one icon)
# TAVS_DIR_IDENTITY_SOURCE="cwd"
#
# Worktree detection — show main→worktree format for git worktrees
# TAVS_DIR_WORKTREE_DETECTION="true"
#
# Registry TTL — how long identity mappings persist (seconds, default 30 days)
# TAVS_IDENTITY_REGISTRY_TTL=2592000
#
# Per-agent overrides:
#   CLAUDE_IDENTITY_MODE="dual"
#   GEMINI_IDENTITY_MODE="single"
#   CLAUDE_DIR_ICON_TYPE="flags"
#   CODEX_DIR_ICON_TYPE="plants"

# ── Title Format Presets ──────────────────────────────────────────────────
# Ready-made format strings. Uncomment ONE to use, or write your own.
#
# Minimal (no identity icons — backward compatible):
# TAVS_TITLE_FORMAT="{FACE} {STATUS_ICON} {AGENTS} {SESSION_ICON} {BASE}"
#
# Standard with dual identity (guillemets auto-injected when dual mode):
#   Leave TAVS_TITLE_FORMAT at default — dual mode auto-wraps {SESSION_ICON}
#   into «{DIR_ICON}|{SESSION_ICON}» via dynamic guillemet injection.
#
# Full Identity (explicit guillemets + session ID):
# TAVS_TITLE_FORMAT="{FACE} {STATUS_ICON} {AGENTS} «{DIR_ICON}|{SESSION_ICON}» {SESSION_ID} {BASE}"
#
# Bubble (future — all info inside guillemets):
# TAVS_TITLE_FORMAT="{FACE} «{STATUS_ICON}|{CONTEXT_FOOD}{CONTEXT_PCT}|{AGENTS}|{SESSION_ICON}|{DIR_ICON}»"

# ── Per-State Title Formats ────────────────────────────────────────────────
# Different title templates for each trigger state. Empty = use TAVS_TITLE_FORMAT.
#
# Additional tokens available (require StatusLine bridge for real-time data):
#   {CONTEXT_PCT}      Percentage number (e.g., 45%)
#   {CONTEXT_FOOD}     Food emoji 21-stage (💧→🍫, 5% steps)
#   {CONTEXT_FOOD_10}  Food emoji 11-stage (💧→🍫, 10% steps)
#   {CONTEXT_ICON}     Color circle (⚪→🔵→🟢→🟡→🟠→🔴→⚫)
#   {CONTEXT_BAR_H}    Horizontal bar 5-char (▓▓░░░)
#   {CONTEXT_BAR_HL}   Horizontal bar 10-char (▓▓▓▓▓░░░░░)
#   {CONTEXT_BAR_V}    Vertical block (▁▂▃▄▅▆▇█)
#   {CONTEXT_BAR_VM}   Vertical + max outline (▄▒)
#   {CONTEXT_BRAILLE}  Braille fill (⠀⠄⠤⠴⠶⠷⠿)
#   {CONTEXT_NUMBER}   Number emoji (0️⃣ through 🔟)
#   {MODEL}            Model display name (e.g., Opus)
#   {COST}             Session cost (e.g., $0.42)
#   {DURATION}         Session duration (e.g., 5m32s)
#   {LINES}            Lines added (e.g., +156)
#   {MODE}             Permission mode (e.g., plan) — always available
#
# TAVS_TITLE_FORMAT_PROCESSING="{FACE} {STATUS_ICON} {CONTEXT_FOOD} {CONTEXT_PCT} {AGENTS} {SESSION_ICON} {BASE}"
# TAVS_TITLE_FORMAT_PERMISSION="{FACE} {STATUS_ICON} {CONTEXT_FOOD} {CONTEXT_PCT} {BASE}"
# TAVS_TITLE_FORMAT_COMPLETE="{FACE} {STATUS_ICON} {COST} {SESSION_ICON} {BASE}"
# TAVS_TITLE_FORMAT_COMPACTING="{FACE} {STATUS_ICON} {CONTEXT_PCT} {BASE}"
# TAVS_TITLE_FORMAT_IDLE=""
# TAVS_TITLE_FORMAT_SUBAGENT=""
# TAVS_TITLE_FORMAT_TOOL_ERROR=""
# TAVS_TITLE_FORMAT_RESET=""

# ── Per-Agent Title Format Overrides ───────────────────────────────────────
# Agent-specific title formats (highest priority in fallback chain):
#   Level 1: {AGENT}_TITLE_FORMAT_{STATE}  (e.g., CLAUDE_TITLE_FORMAT_PERMISSION)
#   Level 2: {AGENT}_TITLE_FORMAT          (e.g., CLAUDE_TITLE_FORMAT)
#   Level 3: TAVS_TITLE_FORMAT_{STATE}     (global per-state, above)
#   Level 4: TAVS_TITLE_FORMAT             (global default)
#
# CLAUDE_TITLE_FORMAT_PERMISSION="{FACE} {STATUS_ICON} {CONTEXT_FOOD} {CONTEXT_PCT} {MODEL} {BASE}"
# GEMINI_TITLE_FORMAT="{FACE} {STATUS_ICON} {BASE}"

# ── Context Icon Customization ─────────────────────────────────────────────
# Replace default food scale (21-stage, 5% steps):
# TAVS_CONTEXT_FOOD_21=("💧" "🥬" "🥦" "🥒" "🥗" "🥝" "🥑" "🍋" "🍌" "🌽" "🧀" "🥨" "🍞" "🥪" "🌮" "🍕" "🌭" "🍔" "🍟" "🍩" "🍫")
#
# Replace color circles (11-stage, 10% steps):
# TAVS_CONTEXT_CIRCLES_11=("⚪" "🔵" "🔵" "🟢" "🟢" "🟡" "🟠" "🟠" "🔴" "🔴" "⚫")
#
# Replace bar characters:
# TAVS_CONTEXT_BAR_FILL="▓"
# TAVS_CONTEXT_BAR_EMPTY="░"

# ── StatusLine Bridge ──────────────────────────────────────────────────────
# The bridge enables real-time context data in titles by reading Claude Code's
# StatusLine JSON. Without it, TAVS estimates context % from transcript file size.
#
# Setup:
#   1. Create ~/.claude/statusline.sh (or add to existing):
#        #!/bin/bash
#        input=$(cat)
#        echo "$input" | ~/.claude/plugins/cache/terminal-agent-visual-signals/tavs/*/src/agents/claude/statusline-bridge.sh
#        # Your statusline output below (optional):
#        echo "$input" | jq -r '"[\(.model.display_name)] \(.context_window.used_percentage // 0)%"'
#
#   2. Add to ~/.claude/settings.json:
#        "statusLine": { "command": "bash ~/.claude/statusline.sh" }
#
# Bridge staleness (seconds before data considered stale):
# TAVS_CONTEXT_BRIDGE_MAX_AGE=30


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  SECTION 4: SPINNER (when TAVS_TITLE_MODE="full")                       ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# Spinner Style — animation pattern for eyes during processing
#   "braille"     - Rotating dots: ⠋ ⠙ ⠹ ⠸
#   "circle"      - Filling circles: ○ ◔ ◑ ◕ ●
#   "block"       - Pulsing bars: ▁ ▂ ▃ ▄ ▅ ▆ ▇ █
#   "eye-animate" - Random eye characters
#   "none"        - Use existing face variants (no animation)
#   "random"      - Random selection per session (recommended)
# TAVS_SPINNER_STYLE="random"

# Eye Synchronization Mode — how the two eyes animate together
#   "sync"      - Both eyes same frame
#   "opposite"  - Eyes half-cycle apart
#   "stagger"   - Left leads, right follows
#   "clockwise" - Both rotate clockwise (braille)
#   "counter"   - Both rotate counter-clockwise
#   "mirror"    - Left increases, right decreases
#   "mirror_inv"- Left decreases, right increases
#   "random"    - Random per session (recommended)
# TAVS_SPINNER_EYE_MODE="random"

# Session Identity — consistent visual identity per session
#   When true, random selections are made once at session start
# TAVS_SESSION_IDENTITY="true"

# Custom spinner frames (override defaults)
# TAVS_SPINNER_FRAMES_BRAILLE=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
# TAVS_SPINNER_FRAMES_CIRCLE=("○" "◔" "◑" "◕" "●" "◕" "◑" "◔")
# TAVS_SPINNER_FRAMES_BLOCK=("▁" "▂" "▃" "▄" "▅" "▆" "▇" "█" "▇" "▆" "▅" "▄" "▃" "▂")

# Per-agent spinner face frames — {L} and {R} are eye placeholders
# CLAUDE_SPINNER_FACE_FRAME='Ǝ[{L} {R}]E'
# GEMINI_SPINNER_FACE_FRAME='ʕ{L}ᴥ{R}ʔ'
# CODEX_SPINNER_FACE_FRAME='ฅ^{L}ﻌ{R}^ฅ'
# OPENCODE_SPINNER_FACE_FRAME='({L}-{R})'


